{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "local_shell|shell|shell_command|exec_command|container.exec|Bash|Shell|grep_files|mcp__",
        "hooks": [
          { "type": "command", "command": "hrbr hook codex pretooluse" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "hrbr hook codex posttooluse" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "hrbr hook codex sessionstart" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "hrbr hook codex userpromptsubmit" }
        ]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "hrbr hook codex stop" }] }
    ]
  }
}
